{
  "name": "proven",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "clean": "rm -rf .next",
    "build": "next build",
    "contract:check": "node scripts/run-genvm-lint.mjs check contracts/proven.py",
    "test:direct": "node scripts/run-direct-tests.mjs",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:integration:localnet": "node scripts/run-integration-tests.mjs --network localnet",
    "test:integration:studionet": "node scripts/run-integration-tests.mjs --network studionet",
    "test:smoke": "node --import tsx --test tests/node/api-validation.test.ts tests/node/contract-smoke.test.ts tests/node/db-index.test.ts",
    "contract:stage": "node scripts/run-staged-contract-workflow.mjs",
    "contract:stage:deploy": "node scripts/run-staged-contract-workflow.mjs --deploy-bradbury",
    "start": "next start",
    "warm:vs-index": "tsx scripts/warm-vs-index.ts",
    "deploy:contract": "node scripts/genlayer-deploy.mjs",
    "deploy:contract:bradbury": "node scripts/genlayer-deploy.mjs --network testnet-bradbury",
    "deploy:contract:localnet": "node scripts/genlayer-deploy.mjs --network localnet",
    "deploy:contract:env": "node scripts/genlayer-deploy.mjs --write-env",
    "deploy:contract:sdk": "npx tsx deploy/deploy.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@xmtp/browser-sdk": "^7.0.0",
    "framer-motion": "^12.38.0",
    "genlayer-js": "^0.23.1",
    "lucide-react": "^0.383.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "nextjs-toploader": "^3.9.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.7.0",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
