# =============================================================================
# PROVEN environment example
# Copy the values you need into .env.local or your deployment provider.
# Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# App + GenLayer contract
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_CONTRACT_ADDRESS=
# NEXT_PUBLIC_CONTRACT_ADDRESS_LOCALNET=
# NEXT_PUBLIC_CONTRACT_ADDRESS_STUDIONET=
# NEXT_PUBLIC_CONTRACT_ADDRESS_TESTNET_ASIMOV=
# NEXT_PUBLIC_CONTRACT_ADDRESS_TESTNET_BRADBURY=
#
# NEXT_PUBLIC_GENLAYER_NETWORK=studionet
# GENLAYER_NETWORK=studionet
# NEXT_PUBLIC_GENLAYER_RPC=
# GENLAYER_RPC=
# NEXT_PUBLIC_GENLAYER_EXPLORER=
# GENLAYER_EXPLORER=
# NEXT_PUBLIC_GENLAYER_MAIN_CONTRACT=
# GENLAYER_MAIN_CONTRACT=

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
# Public DSN used by the browser bundle.
# NEXT_PUBLIC_SENTRY_DSN=
#
# Optional server-only DSN override. Leave empty to reuse NEXT_PUBLIC_SENTRY_DSN.
# SENTRY_DSN=
#
# Optional environment label override for server/edge events.
# SENTRY_ENVIRONMENT=development
#
# Optional source map upload settings for CI/CD.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
#
# PostHog project key and host for product analytics.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Feature flags + AI services
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_SOURCE_DRAFTS=1
# NEXT_PUBLIC_FEATURE_CLAIM_MODERATION=1
# GEMINI_API_KEY=
# CLAIM_DRAFT_MODEL=gemini-2.5-flash
# CLAIM_MODERATION_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# XMTP
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_XMTP_ENV=dev
# NEXT_PUBLIC_FEATURE_XMTP=1
# NEXT_PUBLIC_XMTP_APP_VERSION=proven-app/0.1.0

# -----------------------------------------------------------------------------
# Read index + cron
# -----------------------------------------------------------------------------
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
# CRON_SECRET=
#
# Optional override for the local on-disk VS snapshot cache directory.
# PROVEN_CACHE_DIR=

# -----------------------------------------------------------------------------
# Local tooling + deployment scripts
# -----------------------------------------------------------------------------
# PYTHON_BIN=python
# PYTHONIOENCODING=utf-8
# PYTHONUTF8=1
# GENVM_LINT_BIN=
# GENLAYER_BIN=
#
# DEPLOYER_PRIVATE_KEY=
# DEPLOY_CONTRACT_PATH=contracts/proven.py
#
# GENLAYER_DEPLOY_RECEIPT_RETRIES=60
# GENLAYER_DEPLOY_RECEIPT_INTERVAL_MS=3000
# GENLAYER_DEPLOY_BROADCAST_GRACE_MS=15000
# GENLAYER_DEPLOY_HEARTBEAT_MS=10000

# -----------------------------------------------------------------------------
# Platform-provided / system vars
# These are read in code but are usually set by the runtime, CI, or shell.
# -----------------------------------------------------------------------------
# CI=true
# NODE_ENV=development
# VERCEL=1
# NEXT_RUNTIME=nodejs
# ComSpec=C:\\Windows\\System32\\cmd.exe

# -----------------------------------------------------------------------------
# Planned Phase 1 / Phase 2 placeholders
# These are not read by the app yet. Keep them commented until the matching
# feature lands.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_CLAIM_STRENGTH=1
# PERPLEXITY_API_KEY=
# CURATOR_ADDRESSES=0xabc...,0xdef...
#
# NEXT_PUBLIC_FEATURE_PRIVY=1
# NEXT_PUBLIC_PRIVY_APP_ID=
# PRIVY_APP_SECRET=
#
# NEXT_PUBLIC_TRANSAK_API_KEY=
# TRANSAK_API_SECRET=
#
# ALCHEMY_BASE_RPC_URL=
# NEXT_PUBLIC_BASE_ESCROW_ADDRESS=
#
# TENDERLY_ACCOUNT_SLUG=
# TENDERLY_PROJECT_SLUG=
# TENDERLY_ACCESS_KEY=
#
# SAFE_KEEPER_ADDRESS=
# BITSO_API_KEY=
# BITSO_API_SECRET=
