# =============================================================================
# PROVEN — variables de ejemplo (copiar a .env.local; no commitear secretos)
# =============================================================================

# Contrato y GenLayer (existentes)
# NEXT_PUBLIC_CONTRACT_ADDRESS=
# Se actualiza automáticamente si despliegas con:
# npm run deploy:contract
# NEXT_PUBLIC_GENLAYER_RPC=
# NEXT_PUBLIC_GENLAYER_MAIN_CONTRACT=

# -----------------------------------------------------------------------------
# XMTP (mensajería E2E en el navegador)
# Guía completa: docs/xmtp-integration.md — sección «Variables de entorno»
# Client options: https://docs.xmtp.org/chat-apps/core-messaging/create-a-client
# -----------------------------------------------------------------------------

# Red XMTP: local | dev | production (por defecto en código: dev)
# NEXT_PUBLIC_XMTP_ENV=dev

# Sin esto, XmtpProvider no llama a Client.create (status "disabled").
# Activa con: 1, true, yes
# NEXT_PUBLIC_FEATURE_XMTP=1

# Identificador para telemetría XMTP (recomendado en producción)
# NEXT_PUBLIC_XMTP_APP_VERSION=proven-app/1.0.0

# --- Ejemplo mínimo para desarrollo local (copiar a .env.local y descomentar) ---
# NEXT_PUBLIC_XMTP_ENV=dev
# NEXT_PUBLIC_FEATURE_XMTP=1
# NEXT_PUBLIC_XMTP_APP_VERSION=proven-app/0.1
# -----------------------------------------------------------------------------
# Turso read index (server-only)
# Derived index only. Contract state remains the source of truth.
# -----------------------------------------------------------------------------
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
# CRON_SECRET=
